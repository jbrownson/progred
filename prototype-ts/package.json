{
  "name": "progred",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "scripts": {
    "build": "vite build --config vite.renderer.config.ts && vite build --config vite.main.config.ts && vite build --config vite.preload.config.ts",
    "typecheck": "tsc --noEmit",
    "start": "npm run build && electron .",
    "gen": "vite build --config vite.generator.config.ts && node build/generator.cjs",
    "dist": "electron-packager ."
  },
  "main": "build/main.cjs",
  "author": "Jake Brownson (jake@brainiumstudios.com)",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-packager": "^17.1.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
